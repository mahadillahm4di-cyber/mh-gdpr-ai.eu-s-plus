# ============================================================
# mh-gdpr-ai.eu S+ — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Only .env.example is committed.
# ============================================================

# --- API Server ---
API_PORT=8080
API_HOST=0.0.0.0
API_ENV=development
# Secret key for signing tokens (generate with: openssl rand -hex 32)
API_SECRET_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Ollama (local, no key needed) ---
OLLAMA_HOST=http://localhost:11434

# --- Database ---
# SQLite is default (no config needed). For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/sovereign_ai

# --- Security ---
# Comma-separated allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Rate limit: requests per minute per IP
RATE_LIMIT_RPM=60
# AES-256 encryption key for memory at rest (generate with: openssl rand -hex 32)
MEMORY_ENCRYPTION_KEY=

# --- Redis (optional, for rate limiting in production) ---
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=
